# Icon browser static site for docker compose
FROM node:20-bookworm AS build
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/
COPY apps/auth-api/package.json apps/auth-api/
COPY apps/figma-plugin/package.json apps/figma-plugin/
COPY packages/github-admin/package.json packages/github-admin/
COPY packages/core/package.json packages/core/
COPY packages/catalog/package.json packages/catalog/
COPY packages/custom-icons/package.json packages/custom-icons/
COPY packages/react/package.json packages/react/
COPY packages/vue/package.json packages/vue/
COPY tooling/catalog-gen/package.json tooling/catalog-gen/

RUN pnpm install --frozen-lockfile

COPY . .

ARG VITE_AUTH_API_URL=http://localhost:8787
ARG VITE_GITHUB_REPO=JasonTuTu2/icons-library
ARG VITE_BASE_PATH=/
ENV VITE_AUTH_API_URL=$VITE_AUTH_API_URL
ENV VITE_GITHUB_REPO=$VITE_GITHUB_REPO
ENV VITE_BASE_PATH=$VITE_BASE_PATH

RUN pnpm --filter @JasonTuTu2/github-admin build \
  && pnpm --filter @JasonTuTu2/icons-custom build \
  && pnpm --filter @JasonTuTu2/icons-core build \
  && pnpm --filter @JasonTuTu2/icons-catalog build \
  && pnpm --filter @JasonTuTu2/icons-react build \
  && pnpm --filter @JasonTuTu2/icons-web build

FROM nginx:1.27-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
EXPOSE 80
