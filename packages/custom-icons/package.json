{
  "name": "@JasonTuTu2/icons-custom",
  "version": "0.3.15",
  "description": "Custom brand icons (SVG) and brand images (PNG/JPG)",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/react.js",
    "./dist/vue.js",
    "./dist/react.cjs",
    "./dist/vue.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./collection.json": "./src/collection.json",
    "./images/*": "./images/*"
  },
  "files": [
    "dist",
    "src/collection.json",
    "svg",
    "images"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts src/vue.ts --format esm,cjs --dts --external @iconify/react --external @iconify/vue --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@iconify/react": "^5.0.0 || ^6.0.0",
    "@iconify/vue": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@iconify/react": {
      "optional": true
    },
    "@iconify/vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/react": "^5.1.0",
    "@iconify/vue": "^4.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonTuTu2/icons-library.git",
    "directory": "packages/custom-icons"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
