{
  "name": "@JasonTuTu2/icons-vue",
  "version": "0.3.21",
  "description": "Vue 3 Icon component for brand SVGs",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external vue --external @iconify/vue --external @JasonTuTu2/icons-core --external @JasonTuTu2/icons-custom --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@JasonTuTu2/icons-core": "workspace:*",
    "@JasonTuTu2/icons-custom": "workspace:*"
  },
  "peerDependencies": {
    "@iconify/vue": "^4.0.0 || ^5.0.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "@iconify/vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/vue": "^4.3.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonTuTu2/icons-library.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
