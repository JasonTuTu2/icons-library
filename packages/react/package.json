{
  "name": "@JasonTuTu2/icons-react",
  "version": "0.3.15",
  "description": "React Icon component (Iconify + custom)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external @iconify/react --external @JasonTuTu2/icons-core --external @JasonTuTu2/icons-custom --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@JasonTuTu2/icons-core": "workspace:*",
    "@JasonTuTu2/icons-custom": "workspace:*"
  },
  "peerDependencies": {
    "@iconify/react": "^5.0.0 || ^6.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@iconify/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/react": "^5.1.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JasonTuTu2/icons-library.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
