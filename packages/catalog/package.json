{
  "name": "@genvoice/icons-catalog",
  "version": "0.1.0",
  "description": "Icon metadata catalog for GenVoice Icons browser",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./data.json": "./src/data/icons.json"
  },
  "files": ["dist", "src/data"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --loader .json=json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
