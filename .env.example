# Copy to `.env` in the repo root for `docker compose up`.
# Never commit `.env`.

# GitHub bot PAT: contents:write + actions:write (same as ICON_BROWSER_TOKEN)
GITHUB_TOKEN=ghp_xxx

# owner/repo
GITHUB_REPO=JasonTuTu2/icons-library

# Random long string for signing session JWTs
SESSION_SECRET=replace-with-long-random-secret

# Bootstrap accounts (JSON). First login migrates into Redis.
AUTH_USERS=[{"username":"dev","password":"change-me","role":"dev"}]

# Browser → auth URL (host ports). Must be reachable from your machine.
VITE_AUTH_API_URL=http://localhost:8787
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: Node without Compose (point at a local Redis)
# REDIS_URL=redis://127.0.0.1:6379

# Optional host port overrides
# WEB_PORT=8080
# AUTH_PORT=8787
# REDIS_PORT=6379
