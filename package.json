{
  "name": "genvoice-icons-library",
  "private": true,
  "version": "0.0.0",
  "description": "Brand icon library for React and Vue",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@JasonTuTu2/icons-web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "catalog:gen": "pnpm --filter @JasonTuTu2/catalog-gen start && pnpm --filter @JasonTuTu2/icons-custom build && pnpm --filter @JasonTuTu2/icons-catalog build",
    "catalog:gen:src": "pnpm --filter @JasonTuTu2/catalog-gen start",
    "introduced:gen": "node scripts/build-introduced-versions.mjs",
    "publish-history:gen": "node scripts/build-publish-history.mjs",
    "release-meta:gen": "pnpm introduced:gen && pnpm publish-history:gen",
    "bundle:smoke": "node tooling/bundle-smoke/run.mjs",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "esbuild": "^0.24.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
